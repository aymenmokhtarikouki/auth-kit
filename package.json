{
  "name": "auth-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared identity toolkit — OTP-first authentication (email/phone codes, Google & Apple sign-in) with pluggable sessions. Storage-agnostic: apps plug small stores (Prisma, raw pg, anything). Address book lives in location-kit.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "setup": "npm install --include-workspace-root -w @aymenkits/auth-otp -w @aymenkits/auth-core -w @aymenkits/auth-express && npm run build",
    "build": "npm run build -w @aymenkits/auth-otp -w @aymenkits/auth-core -w @aymenkits/auth-express",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "demo": "npm run dev -w @aymenkits/auth-demo-server"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0"
  }
}
